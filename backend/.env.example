# ─────────────────────────────────────────────────────────────────────────────
# UP Politics Media Tracker — Backend Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Your Vercel/frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Port — AWS/Render sets this automatically; keep 4000 for local dev
PORT=4000

# ── Headless Mode ────────────────────────────────────────────────────────────
# For AWS with Xvfb (recommended): set HEADLESS=false
#   Chrome runs on a virtual display (Xvfb) instead of headless mode.
#   This dramatically reduces Google CAPTCHA since Chrome looks like a real browser.
#   Before starting: run  bash install-aws.sh  (once) then  bash start.sh
#
# For AWS without Xvfb (fallback): set HEADLESS=true
#   Uses Chrome --headless=new mode. More prone to Google CAPTCHA detection.
#
# For local development: leave as false (browser window opens normally)

HEADLESS=false

# ── Chrome / Selenium ────────────────────────────────────────────────────────
# Google Chrome must be installed on the server.
# Local (Windows): Chrome installs automatically via selenium-webdriver
# AWS EC2 setup:   sudo bash install-aws.sh   (installs Chrome + Xvfb + Node)
# selenium-webdriver auto-manages chromedriver — no manual install needed.
